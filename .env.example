# BrainMind — Variables de entorno
# Copia como .env y edita los valores reales

# Base de datos
POSTGRES_PASSWORD=brainmind_dev_password

# Seguridad JWT (genera con: openssl rand -hex 32)
SECRET_KEY=dev_secret_key_change_in_production_min_32_chars

# ── Feature flags IA ──────────────────────────────────────────────────────────
# LLM_PROVIDER: 'ollama' (dev, gratis) | 'claude' (prod, requiere API key)
LLM_PROVIDER=ollama
OLLAMA_CHAT_MODEL=mistral:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# WHISPER_MODE: 'mock' (dev rápido) | 'local' (faster-whisper real)
WHISPER_MODE=mock
WHISPER_MODEL_SIZE=medium

# ── Jitsi (videollamada) ──────────────────────────────────────────────────────
# Para dev local usa meet.jit.si (gratis, sin config)
# Para prod usa tu instancia self-hosted
JITSI_BASE_URL=https://meet.jit.si
JICOFO_AUTH_PASSWORD=jicofo_dev_password
JVB_AUTH_PASSWORD=jvb_dev_password

# ── Email transaccional (Resend) ──────────────────────────────────────────────
# Sin esta clave: emails se loguean en consola y cuentas se auto-verifican (dev)
# Con esta clave: se envían emails reales y se requiere verificación para login
# Plan gratuito: 3.000 emails/mes — https://resend.com
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@tudominio.com

# ── Claude API (solo si LLM_PROVIDER=claude) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Observabilidad ────────────────────────────────────────────────────────────
# Grafana: http://localhost:3001  usuario: admin  contraseña: brainmind
# Prometheus: http://localhost:9090
# Loki: http://localhost:3100
# Tempo: http://localhost:3200
# Cambiar la contraseña de Grafana en producción:
GRAFANA_ADMIN_PASSWORD=brainmind

# OTLP endpoint (no cambiar salvo que muevas el otel-collector)
OTEL_ENDPOINT=http://otel-collector:4317

# Entorno: development | production
# En production los logs salen en JSON puro (para Loki/CloudWatch)
ENVIRONMENT=development
