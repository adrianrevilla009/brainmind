{
  "uid": "brainmind-logs",
  "title": "BrainMind — Logs",
  "tags": ["brainmind"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Errores en tiempo real",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "datasource": { "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "expr": "{service=\"backend\"} | json | level=~\"error|critical\"",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Volumen de logs por nivel",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "uid": "loki" },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"backend\"} | json | level=\"error\" [1m]))",
          "legendFormat": "Errores"
        },
        {
          "expr": "sum(count_over_time({service=\"backend\"} | json | level=\"warning\" [1m]))",
          "legendFormat": "Warnings"
        },
        {
          "expr": "sum(count_over_time({service=\"backend\"} | json | level=\"info\" [1m]))",
          "legendFormat": "Info"
        }
      ]
    },
    {
      "id": 3,
      "title": "Todos los servicios",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{project=\"brainmind_v5\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Errores de frontend capturados",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "uid": "loki" },
      "options": {
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{service=\"backend\"} |= \"FRONTEND\"",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ]
}
